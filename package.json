{
  "name": "@mili-wang/umibot",
  "version": "1.6.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "umibot": "bin/umibot-cli.js"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "skills",
    "index.ts",
    "tsconfig.json",
    "openclaw.plugin.json",
    "clawdbot.plugin.json",
    "moltbot.plugin.json"
  ],
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "moltbot": {
    "extensions": [
